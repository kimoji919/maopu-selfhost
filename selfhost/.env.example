# Use long random values. Do not commit the resulting .env file.
MONGO_ROOT_USERNAME=maopu
MONGO_ROOT_PASSWORD=replace-with-a-long-random-password
JWT_SECRET=replace-with-at-least-32-random-characters

# WeChat Mini Program credentials, used only by the API server.
WECHAT_APPID=wx0000000000000000
WECHAT_APPSECRET=replace-with-your-wechat-app-secret

# Docker exposes this host port; direct Node.js startup uses PORT below.
API_PORT=3000
# The API only binds to localhost by default; reverse-proxy it with HTTPS.
HOST=127.0.0.1
PORT=8788
# URL path mounted by the API. Your Mini Program base URL must include it.
API_BASE_PATH=/maopu/api
# Required only for non-Docker startup. The local MongoDB helper binds only to
# 127.0.0.1; enable MongoDB auth before exposing it beyond this host.
MONGO_URL=mongodb://127.0.0.1:27017/maopu

# Path gateway: only start it after the existing 8787 service has moved to 8789.
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8787
API_TARGET=http://127.0.0.1:8788
LEGACY_TARGET=http://127.0.0.1:8789
